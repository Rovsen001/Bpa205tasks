@using Simulation123.Models
@model List<Product>
<div>
    <a class="btn-primary" asp-controller="Product" asp-action="Create"><h1>Add Product</h1></a>
    <table class="table">
        <thead>
            <tr>
                <th scope="col">#</th>
                <th scope="col">Name</th>
                <th scope="col">Price</th>
                <th scope="col">Description</th>
                <th scope="col">GameId</th>
                <th scope="col">Category</th>
                <th scope="col">Image</th>
                <th scope="col">IsDeleted</th>
                <th scope="col">Actions</th>
            </tr>
        </thead>
        <tbody>
         
                @foreach (Product item in Model )
            {
                <tr>
                    <th scope="row">@item.Id</th>
                    <td>@item.Name</td>
                    <td>@item.Price</td>
                    <td>@item.Description</td>
                    <td>@item.GameId</td>
                    <td>@item.Category.Name</td>
                    <td><img width="50" height="50" src="~/assets/assets/images/@item.ImageUrl" alt="@item.Name" /></td>
                    @if(!item.IsDeleted)
                    {
                        <td class="text-danger">Active</td>
                    }
                    else
                    {
                        <td class="text-succes">Inactive</td>
                    }
                    <td>
                        <a class="btn-warning" asp-controller="Product" asp-action="Update" asp-route-id="@item.Id"> Update </a>
                        @if (!item.IsDeleted)
                        {
                         <form asp-controller="Product" asp-action="Delete" asp-route-id="@item.Id">
                             <button class="btn-danger"> Delete </button>
                         </form>   
                        }
                        else
                        {
                            <form asp-controller="Product" asp-action="Restore" asp-route-id="@item.Id">
                                <button class="btn-success"> Restore </button>
                            </form>
                        }
                    </td>
                     </tr>
                }
           
           
        </tbody>
    </table>
</div>