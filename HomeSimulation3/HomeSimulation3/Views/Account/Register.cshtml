@using HomeSimulation3.ViewModels.Account
@model RegisterVM
<form asp-controller="Account" asp-action="Register" method="post">
    <div class="col-md-12">
        <label>Username</label>
        <input asp-for="@Model.Username" type="text" placeholder="Username" />
        <span class="text-danger" asp-validation-for="@Model.Username"></span>
    </div>
    <div class="col-md-6 col-12">
        <label>First Name</label>
        <input asp-for="@Model.Name" type="text" placeholder="First Name" />
        <span class="text-danger" asp-validation-for="@Model.Name"></span>
    </div>
    <div class="col-md-6 col-12">
        <label>Last Name</label>
        <input asp-for="@Model.Surname" type="text" placeholder="Last Name" />
        <span class="text-danger" asp-validation-for="@Model.Surname"></span>
    </div>
    <div class="col-md-12">
        <label>Email Address*</label>
        <input asp-for="@Model.Email" type="email" placeholder="Email Address" />
        <span class="text-danger" asp-validation-for="@Model.Email"></span>
    </div>
    <div class="col-md-6">
        <label>Password</label>
        <input asp-for="@Model.Password" type="password" placeholder="Password" />
        <span class="text-danger" asp-validation-for="@Model.Password"></span>
    </div>
    <div class="col-md-6">
        <label>Confirm Password</label>
        <input asp-for="@Model.ConfirmPassword" type="password" placeholder="Confirm Password" />
        <span class="text-danger" asp-validation-for="@Model.ConfirmPassword"></span>
    </div>
    <div class="col-12">
        <button type="submit" class="btn btn-custom-size lg-size btn-primary">
            Register
        </button>
    </div>
    <div class="col-12 d-flex">
        <p>Already have an account?</p>
        <a asp-controller="Account" asp-action="Login">Login</a>
    </div>
</form>