@model List<Slider>
<div>
    <form>
    <a class="btn btn-primary" asp-controller="Slider" asp-action="Create" method="post">Add Slider</a>
        </form>
    <table class="table">
        <thead>
            <tr>
                <th scope="col">Id</th>
                <th scope="col">Title</th>
                <th scope="col">Description</th>
                <th scope="col">Delete Status</th>
                <th scope="col">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <th scope="row">@item.Id</th>
                    <td>@item.Title</td>
                    <td>@item.Description</td>
                    <td>
                        <img style="width: 60px; height: 60px" src="~/uploads/slider/@item.ImageUrl" />
                    </td>
                    @if (item.IsDeleted)
                    {
                        <td class="text-success">Active</td>
                    }
                    else
                    {
                        <td class="text-danger">Deleted</td>
                    }
                    <td>
                        <a asp-controller="Slider" asp-action="Update" asp-route-id="@item.Id" class="btn btn-warning">Update</a>
                    </td>
                    <td>
                        @if (!item.IsDeleted)
                        {
                            <form asp-controller="Slider" asp-action="Delete" asp-route-id="@item.Id" method="post"> <button class="btn btn-danger">Delete</button></form>                
                        }
                        else
                        {
                            <form asp-controller="Slider" asp-action="Restore" asp-route-id="@item.Id" method="post"> <button class="btn btn-success">Restore</button></form>

                        }
                    </td>
                    
            </tr>
            }
        </tbody>
    </table>
</div>