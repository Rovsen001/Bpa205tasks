@using DigiMediaTask.Models

@model Project

<div>
    <h1 class="text-primary">Add Project</h1>
    <form asp-controller="Project" asp-action="Create" method="post">
        <div class="mb-3">
            <label for="title" class="form-label">Title</label>
            <input asp-for="@Model.Profession" type="text" class="form-control" id="title" placeholder="Add title...">
        </div>
        <div class="mb-3">
            <label for="desc" class="form-label">Description</label>
            <input asp-for="@Model.Category" type="text" class="form-control" id="desc" placeholder="Add description...">
        </div>
    
        <div class="mb-3">
            <label for="imgUrl" class="form-label">Image URL</label>
            <input asp-for="@Model.ImageUrl" type="text" class="form-control" id="imgUrl">
        </div>
        <button type="submit" class="btn btn-primary">Submit</button>
    </form>
</div>